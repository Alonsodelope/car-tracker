# Database — use your Neon connection string in production
# (Neon dashboard → your project → Connection string → copy the "pooled" URL)
DATABASE_URL=postgresql://tracker:tracker_pass@localhost:5432/bmw_m2_tracker

# App — set to your Vercel URL in production (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sync security token (used to protect the /api/sync endpoint)
# Generate a random string: openssl rand -hex 32
SYNC_SECRET_TOKEN=change-me-to-a-random-secret
